<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Répartition des charges</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #f7f6f3; --surface: #fff; --border: #e4e2db;
    --text: #1a1a18; --muted: #7a7870;
    --a: #2563a8; --a-light: #e8f0fb;
    --b: #1a7a5e; --b-light: #e4f5ef;
    --radius: 10px;
  }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; padding: 2rem 1rem 4rem; font-size: 15px; line-height: 1.6; }
  .container { max-width: 700px; margin: 0 auto; }
  header { margin-bottom: 2rem; }
  header h1 { font-size: 22px; font-weight: 600; letter-spacing: -0.3px; }
  header p { color: var(--muted); font-size: 14px; margin-top: 4px; }
  .saved-badge { display: inline-block; font-size: 12px; color: #1a7a5e; background: #e4f5ef; border-radius: 20px; padding: 2px 10px; margin-left: 10px; vertical-align: middle; opacity: 0; transition: opacity 0.4s; }
  .saved-badge.show { opacity: 1; }
  .info-box { background: #fffbea; border: 1px solid #f0d060; border-radius: var(--radius); padding: 0.9rem 1.1rem; margin-bottom: 1rem; font-size: 13px; color: #7a6010; line-height: 1.5; }
  .info-box strong { color: #5a4500; }
  .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem 1.5rem; margin-bottom: 1rem; }
  .card h2 { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.6px; color: var(--muted); margin-bottom: 1rem; }
  .salaires { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .person-input label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px; }
  .person-input.a label { color: var(--a); }
  .person-input.b label { color: var(--b); }
  .input-wrap { display: flex; align-items: center; border: 1px solid var(--border); border-radius: 7px; overflow: hidden; }
  .input-wrap:focus-within { border-color: #aaa; }
  .input-wrap input { flex: 1; border: none; outline: none; padding: 8px 10px; font-size: 15px; font-family: inherit; background: transparent; color: var(--text); width: 100%; }
  .input-wrap span { padding: 0 10px; color: var(--muted); font-size: 14px; border-left: 1px solid var(--border); background: var(--bg); align-self: stretch; display: flex; align-items: center; }
  .section-tabs { display: flex; gap: 6px; margin-bottom: 1rem; flex-wrap: wrap; }
  .tab-btn { font-size: 12px; font-weight: 600; padding: 4px 12px; border-radius: 20px; border: 1px solid var(--border); background: none; cursor: pointer; color: var(--muted); font-family: inherit; transition: all 0.15s; }
  .tab-btn.active-commune { background: #e8f0fb; color: var(--a); border-color: #c5d9f3; }
  .tab-btn.active-ange { background: #ede9fe; color: #5b21b6; border-color: #c4b5fd; }
  .tab-btn.active-daphnee { background: var(--b-light); color: var(--b); border-color: #b5ddd2; }
  .col-headers { display: grid; grid-template-columns: 1fr 120px 28px; gap: 8px; margin-bottom: 6px; padding: 0 2px; }
  .col-headers span { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600; }
  .charge-row { display: grid; grid-template-columns: 1fr 120px 28px; gap: 8px; align-items: center; margin-bottom: 7px; }
  .charge-row input { border: 1px solid var(--border); border-radius: 7px; padding: 7px 10px; font-size: 14px; font-family: inherit; background: var(--surface); color: var(--text); outline: none; width: 100%; transition: border-color 0.15s; }
  .charge-row input:focus { border-color: #aaa; }
  .btn-remove { background: none; border: 1px solid var(--border); border-radius: 6px; width: 28px; height: 28px; cursor: pointer; color: var(--muted); font-size: 16px; display: flex; align-items: center; justify-content: center; transition: all 0.15s; flex-shrink: 0; }
  .btn-remove:hover { background: #ffeaea; color: #c0392b; border-color: #f5c6c6; }
  .btn-add { background: none; border: 1px dashed var(--border); border-radius: 7px; padding: 7px 14px; font-size: 13px; font-family: inherit; color: var(--muted); cursor: pointer; margin-top: 4px; width: 100%; transition: all 0.15s; }
  .btn-add:hover { background: var(--bg); color: var(--text); border-color: #bbb; }
  .results-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  .result-card { border-radius: var(--radius); padding: 1.1rem 1.25rem; }
  .result-card.a { background: var(--a-light); border: 1px solid #c5d9f3; }
  .result-card.b { background: var(--b-light); border: 1px solid #b5ddd2; }
  .result-card .person-name { font-size: 13px; font-weight: 600; margin-bottom: 8px; }
  .result-card.a .person-name { color: var(--a); }
  .result-card.b .person-name { color: var(--b); }
  .bar-bg { background: rgba(0,0,0,0.08); border-radius: 4px; height: 5px; margin-bottom: 10px; overflow: hidden; }
  .bar-fill { height: 5px; border-radius: 4px; transition: width 0.4s ease; }
  .result-card.a .bar-fill { background: var(--a); }
  .result-card.b .bar-fill { background: var(--b); }
  .result-line { display: flex; justify-content: space-between; font-size: 13px; color: var(--muted); margin-bottom: 3px; }
  .result-line strong { color: var(--text); }
  .result-total { font-size: 22px; font-weight: 600; margin-top: 8px; letter-spacing: -0.5px; }
  .result-card.a .result-total { color: var(--a); }
  .result-card.b .result-total { color: var(--b); }
  .reste { margin-top: 8px; padding-top: 8px; border-top: 1px solid rgba(0,0,0,0.08); font-size: 13px; display: flex; justify-content: space-between; align-items: center; }
  .reste-label { color: var(--muted); }
  .reste-value { font-weight: 600; font-size: 15px; }
  .result-card.a .reste-value { color: var(--a); }
  .result-card.b .reste-value { color: var(--b); }
  .reste-pct { font-size: 11px; opacity: 0.7; margin-left: 4px; }
  .detail-section { margin-top: 8px; padding-top: 8px; border-top: 1px solid rgba(0,0,0,0.08); }
  .dl { font-size: 12px; color: var(--muted); margin-bottom: 2px; display: flex; justify-content: space-between; gap: 8px; }
  .dl span:last-child { font-weight: 500; color: var(--text); white-space: nowrap; }
  .grand-total { background: var(--text); color: white; border-radius: var(--radius); padding: 1rem 1.5rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; }
  .grand-total span { font-size: 13px; opacity: 0.7; }
  .grand-total strong { font-size: 20px; font-weight: 600; }
  .reset-btn { font-size: 12px; color: var(--muted); background: none; border: none; cursor: pointer; text-decoration: underline; margin-top: 1rem; display: block; }
  @media (max-width: 500px) { .salaires, .results-grid { grid-template-columns: 1fr; } }
</style>
</head>
<body>
<div class="container">
  <header>
    <h1>Répartition des charges <span class="saved-badge" id="saved-badge">✓ Sauvegardé</span></h1>
    <p>Données sauvegardées automatiquement dans ce navigateur.</p>
  </header>

  <div class="info-box">
    <strong>Logique utilisée :</strong> la part des charges communes est calculée sur le <strong>revenu disponible</strong> de chacun (salaire - charges perso), pas sur le salaire brut. Ainsi les deux gardent le même pourcentage de reste pour vivre.
  </div>

  <div class="card">
    <h2>Salaires mensuels nets</h2>
    <div class="salaires">
      <div class="person-input a">
        <label>Ange</label>
        <div class="input-wrap">
          <input type="number" id="sal-a" min="0" oninput="save();calc()">
          <span>€</span>
        </div>
      </div>
      <div class="person-input b">
        <label>Daphnée</label>
        <div class="input-wrap">
          <input type="number" id="sal-b" min="0" oninput="save();calc()">
          <span>€</span>
        </div>
      </div>
    </div>
  </div>

  <div class="card">
    <h2>Charges</h2>
    <div class="section-tabs">
      <button class="tab-btn" id="tab-commune" onclick="setTab('commune')">Communes</button>
      <button class="tab-btn" id="tab-ange" onclick="setTab('ange')">Perso Ange</button>
      <button class="tab-btn" id="tab-daphnee" onclick="setTab('daphnee')">Perso Daphnée</button>
    </div>
    <div class="col-headers"><span>Nom</span><span>Montant (€)</span><span></span></div>
    <div id="charges-list"></div>
    <button class="btn-add" onclick="addCharge()">+ Ajouter une charge</button>
  </div>

  <div class="card">
    <h2>Résultat mensuel</h2>
    <div class="results-grid" id="results-grid"></div>
    <div id="grand-total"></div>
  </div>

  <button class="reset-btn" onclick="resetData()">Réinitialiser aux données d'origine</button>
</div>

<script>
var DEFAULTS = {
  salA: 2500, salB: 2500,
  commune: [
    {id:1,name:"Scarlet",amount:34},
    {id:2,name:"Ring",amount:9.99},
    {id:3,name:"Netflix",amount:16.99},
    {id:4,name:"Vandenborre",amount:14.99},
    {id:5,name:"Farys",amount:564.11},
    {id:6,name:"Femme de ménage",amount:120},
    {id:7,name:"Basic fit",amount:34.99},
    {id:8,name:"Familiale",amount:9.66},
    {id:9,name:"Hellofresh",amount:350},
    {id:10,name:"Assurance habitation",amount:57.56},
    {id:11,name:"Amazon",amount:2.99},
    {id:12,name:"Courses",amount:650}
  ],
  ange: [
    {id:20,name:"Assurances auto",amount:178},
    {id:21,name:"DAZN",amount:24.99},
    {id:22,name:"HP Print",amount:5.49},
    {id:23,name:"Claude",amount:21.78},
    {id:24,name:"iCloud+",amount:2.99},
    {id:25,name:"Notion",amount:27.83},
    {id:26,name:"Épargne pension",amount:87.5}
  ],
  daphnee: [
    {id:30,name:"Assurances voiture",amount:160.06},
    {id:31,name:"Spotify",amount:11.99},
    {id:32,name:"Fitbit",amount:8.99},
    {id:33,name:"Claude",amount:21.78},
    {id:34,name:"iCloud+",amount:2.99}
  ]
};

var nextId = 100;
var currentTab = 'commune';
var data;

function loadData() {
  try {
    var s = localStorage.getItem('charges-repartition-v2');
    data = s ? JSON.parse(s) : JSON.parse(JSON.stringify(DEFAULTS));
  } catch(e) { data = JSON.parse(JSON.stringify(DEFAULTS)); }
  document.getElementById('sal-a').value = data.salA;
  document.getElementById('sal-b').value = data.salB;
}

function resetData() {
  if (!confirm("Réinitialiser toutes les données aux valeurs d'origine ?")) return;
  data = JSON.parse(JSON.stringify(DEFAULTS));
  document.getElementById('sal-a').value = data.salA;
  document.getElementById('sal-b').value = data.salB;
  localStorage.setItem('charges-repartition-v2', JSON.stringify(data));
  setTab(currentTab); calc();
}

var saveTimer;
function save() {
  data.salA = +document.getElementById('sal-a').value || 0;
  data.salB = +document.getElementById('sal-b').value || 0;
  try { localStorage.setItem('charges-repartition-v2', JSON.stringify(data)); } catch(e) {}
  clearTimeout(saveTimer);
  var b = document.getElementById('saved-badge');
  b.classList.add('show');
  saveTimer = setTimeout(function(){ b.classList.remove('show'); }, 1500);
}

function setTab(tab) {
  currentTab = tab;
  ['commune','ange','daphnee'].forEach(function(t) {
    document.getElementById('tab-'+t).className = 'tab-btn' + (t === tab ? ' active-'+t : '');
  });
  renderCharges();
}

function renderCharges() {
  var list = document.getElementById('charges-list');
  list.innerHTML = '';
  data[currentTab].forEach(function(c) {
    var row = document.createElement('div');
    row.className = 'charge-row';
    row.innerHTML =
      '<input type="text" value="' + c.name.replace(/"/g,'') + '" placeholder="Nom" oninput="updateCharge(' + c.id + ',\'name\',this.value)">' +
      '<input type="number" value="' + c.amount + '" min="0" step="0.01" oninput="updateCharge(' + c.id + ',\'amount\',+this.value)">' +
      '<button class="btn-remove" onclick="removeCharge(' + c.id + ')">×</button>';
    list.appendChild(row);
  });
}

function addCharge() {
  data[currentTab].push({id:nextId++,name:"",amount:0});
  renderCharges(); save(); calc();
}
function removeCharge(id) {
  data[currentTab] = data[currentTab].filter(function(c){ return c.id !== id; });
  renderCharges(); save(); calc();
}
function updateCharge(id, field, val) {
  var c = data[currentTab].find(function(c){ return c.id === id; });
  if (c) c[field] = val;
  save(); calc();
}

function fmt(n) {
  return (+n||0).toLocaleString('fr-FR',{minimumFractionDigits:2,maximumFractionDigits:2}) + ' €';
}
function sum(arr) { return arr.reduce(function(s,c){ return s + (+c.amount||0); }, 0); }

function calc() {
  var salA = +document.getElementById('sal-a').value || 0;
  var salB = +document.getElementById('sal-b').value || 0;
  var persoA = sum(data.ange);
  var persoB = sum(data.daphnee);
  var totalCommune = sum(data.commune);

  // Revenu disponible = salaire - charges perso
  var dispA = Math.max(0, salA - persoA);
  var dispB = Math.max(0, salB - persoB);
  var totalDisp = dispA + dispB;

  // Part des communes proportionnelle au revenu disponible
  var partA = totalDisp > 0 ? dispA / totalDisp : 0.5;
  var partB = 1 - partA;

  var communeA = totalCommune * partA;
  var communeB = totalCommune * partB;
  var totalPayeA = communeA + persoA;
  var totalPayeB = communeB + persoB;
  var resteA = salA - totalPayeA;
  var resteB = salB - totalPayeB;
  var restePctA = salA > 0 ? (resteA / salA * 100) : 0;
  var restePctB = salB > 0 ? (resteB / salB * 100) : 0;

  var detailA = data.ange.map(function(c){ return '<div class="dl"><span>'+(c.name||'—')+'</span><span>'+fmt(c.amount)+'</span></div>'; }).join('');
  var detailB = data.daphnee.map(function(c){ return '<div class="dl"><span>'+(c.name||'—')+'</span><span>'+fmt(c.amount)+'</span></div>'; }).join('');

  document.getElementById('results-grid').innerHTML =
    '<div class="result-card a">' +
      '<div class="person-name">Ange — ' + (partA*100).toFixed(1) + '% communes</div>' +
      '<div class="bar-bg"><div class="bar-fill" style="width:' + (partA*100).toFixed(1) + '%"></div></div>' +
      '<div class="result-line"><span>Part communes</span><strong>' + fmt(communeA) + '</strong></div>' +
      '<div class="result-line"><span>Charges perso</span><strong>' + fmt(persoA) + '</strong></div>' +
      '<div class="result-total">' + fmt(totalPayeA) + ' payés</div>' +
      '<div class="reste">' +
        '<span class="reste-label">Reste pour vivre</span>' +
        '<span class="reste-value">' + fmt(resteA) + '<span class="reste-pct">(' + restePctA.toFixed(1) + '%)</span></span>' +
      '</div>' +
      '<div class="detail-section">' + detailA + '</div>' +
    '</div>' +
    '<div class="result-card b">' +
      '<div class="person-name">Daphnée — ' + (partB*100).toFixed(1) + '% communes</div>' +
      '<div class="bar-bg"><div class="bar-fill" style="width:' + (partB*100).toFixed(1) + '%"></div></div>' +
      '<div class="result-line"><span>Part communes</span><strong>' + fmt(communeB) + '</strong></div>' +
      '<div class="result-line"><span>Charges perso</span><strong>' + fmt(persoB) + '</strong></div>' +
      '<div class="result-total">' + fmt(totalPayeB) + ' payés</div>' +
      '<div class="reste">' +
        '<span class="reste-label">Reste pour vivre</span>' +
        '<span class="reste-value">' + fmt(resteB) + '<span class="reste-pct">(' + restePctB.toFixed(1) + '%)</span></span>' +
      '</div>' +
      '<div class="detail-section">' + detailB + '</div>' +
    '</div>';

  document.getElementById('grand-total').innerHTML =
    '<div class="grand-total">' +
      '<span>Charges communes : ' + fmt(totalCommune) + '</span>' +
      '<strong>' + fmt(totalPayeA + totalPayeB) + ' / mois</strong>' +
    '</div>';
}

loadData();
setTab('commune');
calc();
</script>
</body>
</html>
